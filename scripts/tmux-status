#!/bin/sh
# Tmux status-right script: memory, swap, avg CPU % with meter, temps, date/time
STATEFILE="/tmp/.tmux-cpu-prev"

# --- Memory ---
mem_total=$(awk '/^MemTotal/ {t=$2} /^MemAvailable/ {a=$2} END {printf "%.1f/%.1fG", (t-a)/1048576, t/1048576}' /proc/meminfo)

# --- Swap ---
swap=$(awk '/^SwapTotal/ {t=$2} /^SwapFree/ {f=$2} END {printf "%.1f/%.1fG", (t-f)/1048576, t/1048576}' /proc/meminfo)

# --- Average CPU % (compare to previous snapshot) ---
curr_file=$(mktemp)
grep '^cpu[0-3] ' /proc/stat > "$curr_file"

if [ -f "$STATEFILE" ]; then
  cpu_info=$(awk '
    NR==FNR { u[NR]=$2; n[NR]=$3; s[NR]=$4; id[NR]=$5; w[NR]=$6; ir[NR]=$7; si[NR]=$8; st[NR]=$9; next }
    {
      i=FNR
      pu = u[i]+n[i]+s[i]+id[i]+w[i]+ir[i]+si[i]+st[i]
      cu = $2+$3+$4+$5+$6+$7+$8+$9
      pi = id[i]+w[i]
      ci = $5+$6
      dt = cu - pu
      di = ci - pi
      if (dt > 0) sum += (dt-di)*100/dt
      count++
    }
    END {
      avg = (count > 0) ? sum/count : 0
      filled = int(avg * 15 / 100 + 0.5)
      if (filled > 15) filled = 15
      bar = ""
      for (i = 1; i <= filled; i++) bar = bar "\xe2\x96\x92"
      for (i = filled+1; i <= 15; i++) bar = bar "\xe2\x96\x91"
      printf "%3.0f%% %s", avg, bar
    }
  ' "$STATEFILE" "$curr_file")
else
  cpu_info="  ?% ░░░░░░░░░░░░░░░"
fi

cp "$curr_file" "$STATEFILE"
rm -f "$curr_file"

# --- CPU Temp (average of cores) ---
avg_temp=$(sensors 2>/dev/null | awk '/^Core [0-3]:/ {
  gsub(/\+/,"",$3); gsub(/°C/,"",$3); sum+=int($3); count++
}
END {
  if (count > 0) {
    avg = sum/count
    if (avg >= 90) printf "#[fg=colour196]%d°#[fg=default]", avg
    else printf "%d°", avg
  } else printf "?°"
}')

# --- Date/Time ---
datetime=$(date '+%b-%d %H:%M:%S')

# --- Output ---
printf "MEM: %s | SWP: %s | CPU:%s | TEMP: %s | %s" "$mem_total" "$swap" "$cpu_info" "$avg_temp" "$datetime"
